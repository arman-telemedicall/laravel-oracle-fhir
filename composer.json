{
    "name": "arman-telemedicall/laravel-epic-fhir",
    "description": "Epic FHIR client integration for Laravel with SMART on FHIR support",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Teleminergmbh\\EpicFhir\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Teleminergmbh\\EpicFhir\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/http": "^11.0 || ^12.0",
        "illuminate/cache": "^11.0 || ^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^1.0"
    },
    "scripts": {
        "test": "pest",
        "test-coverage": "pest --coverage",
        "analyse": "phpstan analyse --memory-limit=1G",
        "format": "pint",
        "format-test": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Teleminergmbh\\EpicFhir\\EpicFhirServiceProvider"
            ],
            "aliases": {
                "EpicFhir": "Teleminergmbh\\EpicFhir\\Facades\\EpicFhir"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
