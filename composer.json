{
    "name": "arman-telemedicall/laravel-oracle-fhir",
    "description": "Oracle FHIR client integration for Laravel with SMART on FHIR support",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Telemedicall\\OracleFhir\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Telemedicall\\OracleFhir\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Telemedicall\\OracleFhir\\OracleFhirServiceProvider"
            ],
            "aliases": {
                "OracleFhir": "Telemedicall\\OracleFhir\\Facades\\OracleFhir"
            }
        }
    },
	"repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/arman-telemedicall/laravel-oracle-fhir"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
